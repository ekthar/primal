NODE_ENV=production
PORT=4000

APP_BASE_URL=https://api.example.com
WEB_BASE_URL=https://example.pages.dev
CORS_ORIGINS=https://example.pages.dev,https://www.example.com

DATABASE_URL=postgresql://primal:CHANGE_ME_STRONG_DB_PASSWORD@127.0.0.1:5432/primal
PG_SSL=false
PG_SSL_REJECT_UNAUTHORIZED=false

JWT_SECRET=CHANGE_ME_64_PLUS_RANDOM_CHARS
PDF_SIGNATURE_SECRET=CHANGE_ME_64_PLUS_RANDOM_CHARS
PDF_VERIFY_BASE_URL=https://api.example.com/api/public/verify/application-signature

UPLOAD_STORAGE_PROVIDER=local
UPLOAD_DIR=/var/lib/primal/uploads
MAX_UPLOAD_MB=10

RESEND_API_KEY=
RESEND_FROM=Primal <no-reply@example.com>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
