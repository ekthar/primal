#!/usr/bin/env bash
# primal-deploy — pull the latest main, install deps, run migrations, restart the
# api service. Designed to live at /usr/local/bin/primal-deploy on the Oracle VM.
#
# Idempotent. Safe to re-run.
set -euo pipefail

REPO_DIR="${PRIMAL_REPO_DIR:-/srv/primal/app}"
ENV_FILE="${PRIMAL_ENV_FILE:-/etc/primal/api.env}"
SERVICE_NAME="${PRIMAL_SERVICE_NAME:-primal-api}"
RUN_AS_USER="${PRIMAL_RUN_AS_USER:-primal}"

err() { echo "primal-deploy: $*" >&2; exit 1; }

[[ -d "$REPO_DIR/.git" ]] || err "Repo not found at $REPO_DIR (set PRIMAL_REPO_DIR)"
[[ -f "$ENV_FILE" ]] || err "Env file not found at $ENV_FILE (set PRIMAL_ENV_FILE)"

echo "==> pulling latest main"
sudo -u "$RUN_AS_USER" git -C "$REPO_DIR" fetch origin
sudo -u "$RUN_AS_USER" git -C "$REPO_DIR" checkout main
sudo -u "$RUN_AS_USER" git -C "$REPO_DIR" pull --ff-only origin main

echo "==> installing backend deps"
sudo -u "$RUN_AS_USER" npm --prefix "$REPO_DIR/backend-node" ci --omit=dev

echo "==> running database migrations"
set -a
# shellcheck disable=SC1090
. "$ENV_FILE"
set +a
sudo -u "$RUN_AS_USER" -E npm --prefix "$REPO_DIR/backend-node" run migrate

echo "==> restarting $SERVICE_NAME"
systemctl restart "$SERVICE_NAME"
sleep 2
systemctl status "$SERVICE_NAME" --no-pager | head -8

echo "==> health check"
curl -s -o /dev/null -w "  api health: %{http_code}\n" http://127.0.0.1:8080/api/public/home || true

echo "==> done"
